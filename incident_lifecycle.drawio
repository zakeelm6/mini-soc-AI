        <mxCell id="leg1" value="&lt;font style='font-size:9px;'&gt;🟡 OPEN : créé automatiquement par l'Ensemble IA ou manuellement&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;" vertex="1" parent="1">
